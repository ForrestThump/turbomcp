          "type": "number",
          "format": "double"
        }
      },
      "additionalProperties": false
    },
    "name": "mul"
  },
  {
    "description": "Run a query, mirroring `region` into a request header.",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": [
        "region",
        "sql"
      ],
      "properties": {
        "region": {
          "type": "string",
          "x-mcp-header": "region"
        },
        "sql": {
          "description": "The SQL to run",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "name": "query"
  }
