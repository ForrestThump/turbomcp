      "type": "object",
      "required": [
        "a"
      ],
      "properties": {
        "a": {
          "type": "number",
          "format": "double"
        },
        "b": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        }
      },
      "additionalProperties": false
    },
    "name": "add"
  },
  {
    "description": "Say hello to someone",
    "inputSchema": {
